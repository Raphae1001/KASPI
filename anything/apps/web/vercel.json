{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "react-router",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://instant-site-magic-48.vercel.app/ http://localhost:3000"
                }
            ]
        }
    ]
}